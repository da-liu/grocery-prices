CURSOR_API_KEY=cursor_your_key_here
GOOGLE_API_KEY=your_google_api_key_here

GROCERY_EXTRACT_BACKEND=cursor
# Default production LLM input reduction uses 25% of the original linear size.
GROCERY_EXTRACT_SCALE_PCT=25
GROCERY_API_PORT=8765
GROCERY_API_URL=https://api-g.daliu.ca
GROCERY_CORS_ORIGINS=https://g.daliu.ca,http://localhost:41873

# Logging (stdout captured by launchd to ~/Library/Logs/grocery-prices-api.log)
GROCERY_LOG_LEVEL=INFO
GROCERY_LOG_FORMAT=text
