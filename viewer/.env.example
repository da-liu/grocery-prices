# Google Maps Static API key (Settings store overview map).
# Enable "Maps Static API" in Google Cloud and restrict by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Public site origin for ring-dot map marker PNGs (Google fetches these server-side).
VITE_PUBLIC_SITE_ORIGIN=https://g.daliu.ca

# Optional: extract server URL for local dev (defaults to same origin).
# VITE_API_URL=http://127.0.0.1:8765
